     return video
 
 
+def _shift_tensor_spatial(mask_tensor, shift_y=0, shift_x=0):
+    if shift_y == 0 and shift_x == 0:
+        return mask_tensor
+    shifted = torch.roll(mask_tensor, shifts=(shift_y, shift_x), dims=(-2, -1))
+    if shift_y > 0:
+        shifted[..., :shift_y, :] = 0
+    elif shift_y < 0:
+        shifted[..., shift_y:, :] = 0
+    if shift_x > 0:
+        shifted[..., :, :shift_x] = 0
+    elif shift_x < 0:
+        shifted[..., :, shift_x:] = 0
+    return shifted
+
+
+def _apply_mask_ablation(input_mask, mode="quadmask", affected_mask_shift_px=0, affected_mask_dropout=0.0):
+    if mode in [None, "quadmask"]:
+        return input_mask
+
+    primary = torch.isclose(input_mask, torch.tensor(1.0, device=input_mask.device, dtype=input_mask.dtype))
+    overlap = torch.isclose(input_mask, torch.tensor((255.0 - 63.0) / 255.0, device=input_mask.device, dtype=input_mask.dtype))
+    affected = torch.isclose(input_mask, torch.tensor((255.0 - 127.0) / 255.0, device=input_mask.device, dtype=input_mask.dtype))
+
+    if mode in ["primary_only", "drop_affected"]:
+        ablated = torch.zeros_like(input_mask)
+        ablated[primary | overlap] = 1.0
+        return ablated
+
+    if mode == "corrupted_affected":
+        affected_mask = (affected | overlap).to(input_mask.dtype)
+        if affected_mask_shift_px != 0:
+            affected_mask = _shift_tensor_spatial(affected_mask, shift_x=int(affected_mask_shift_px))
+        if affected_mask_dropout > 0:
+            keep = (torch.rand_like(affected_mask) > affected_mask_dropout).to(input_mask.dtype)
+            affected_mask = affected_mask * keep
+
+        ablated = torch.zeros_like(input_mask)
+        ablated[primary] = 1.0
+        ablated[affected_mask > 0.5] = (255.0 - 127.0) / 255.0
+        overlap_mask = primary & (affected_mask > 0.5)
+        ablated[overlap_mask] = (255.0 - 63.0) / 255.0
+        return ablated
+
+    raise ValueError(f"Unknown mask_ablation_mode: {mode}")
+
+
